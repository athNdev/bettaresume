{
	"$schema": "../node_modules/wrangler/config-schema.json",
	"compatibility_date": "2026-01-08",
	"compatibility_flags": ["nodejs_compat"],
	"name": "bettaresume-api-server",
	"main": "./src/server.ts",
	// No route / custom_domain — let wrangler dev serve on localhost directly
	"workers_dev": true,
	"d1_databases": [
		{
			"binding": "bettaresume_d1",
			"database_name": "bettaresume",
			"database_id": "local-dev",
			"migrations_dir": "./drizzle"
		}
	],
	"vars": {
		"CLERK_PUBLISHABLE_KEY": "$CLERK_PUBLISHABLE_KEY"
	},
	"dev": {
		"port": 4000
	}
}
