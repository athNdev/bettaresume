# @clerk/fastify
CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_key_here
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key_here

# Set if manually applying migrations to remote D1 database, leave empty otherwise
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_DATABASE_ID=
CLOUDFLARE_D1_TOKEN=

# Allowed CORS origin (restrict in production, defaults to * if unset)
ALLOWED_ORIGIN=http://localhost:3000

# set to ./src/db/db.sqlite if developing locally, leave empty otherwise
LOCAL_DB_PATH=./src/db/db.sqlite
