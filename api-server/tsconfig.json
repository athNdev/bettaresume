{
  "compilerOptions": {
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "outDir": "./dist",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@bettaresume/types": ["../packages/types/src/index.ts"],
      "@bettaresume/types/*": ["../packages/types/src/*"]
    }
  },
  "include": ["src/**/*", "../packages/types/src/**/*"],
  "exclude": ["node_modules", "dist"]
}
