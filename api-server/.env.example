# Turso Database URL
# Get this from: https://turso.tech
# Format: libsql://your-database-name-your-org.turso.io
TURSO_DATABASE_URL=

# Turso Auth Token
# Get this from: turso db tokens create your-database-name
TURSO_AUTH_TOKEN=

# JWT Secret for auth (generate a random string)
# openssl rand -base64 32
JWT_SECRET=your-jwt-secret-here

# Frontend URL for CORS (your SPA URL)
FRONTEND_URL=http://localhost:3000
